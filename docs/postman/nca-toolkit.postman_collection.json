                  "pm.test('Status is 202', () => pm.response.to.have.status(202));",
                  "pm.test('Returns a job_id we can poll', () => {",
                  "  const r = pm.response.json();",
                  "  pm.expect(r).to.have.property('job_id');",
                  "  if (r.job_id) pm.environment.set('lastJobId', r.job_id);",
                  "});",
                  "console.log('Check webhook receiver at', pm.environment.get('webhookUrl'), 'in a few seconds');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"media_url\": \"{{sampleVideoUrl}}\",\n  \"webhook_url\": \"{{webhookUrl}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/v1/media/metadata",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "media", "metadata"]
            }
          }
        },
        {
          "name": "POST /v1/toolkit/job/status (poll {{lastJobId}})",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Status field present', () => {",
                  "    const r = pm.response.json();",
                  "    pm.expect(JSON.stringify(r)).to.match(/queued|running|done|failed|submitted/);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"job_id\": \"{{lastJobId}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/v1/toolkit/job/status",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "toolkit", "job", "status"]
            }
          }
        }
      ]
    }
  ]
}
